{
  "name": "wp-migration-poc",
  "version": "1.0.0",
  "description": "Source content to AEM migration (extract, DAM assets, FileVault package)",
  "private": true,
  "scripts": {
    "install:ui": "npm install --prefix server && npm install --prefix web",
    "dev:ui": "npm run dev:all --prefix server",
    "build:ui": "npm run build --prefix web",
    "start:ui": "npm start --prefix server",
    "extract": "node scripts/extract.js",
    "build:sample-docs": "node scripts/build-sample-documents.js",
    "transform": "node scripts/transform.js",
    "generate": "node scripts/generate.js",
    "migrate-assets": "node scripts/migrate-assets.js",
    "build:aem-package": "node scripts/build-aem-package.js",
    "pipeline:aem": "node scripts/extract.js && node scripts/transform.js && node scripts/generate.js && node scripts/build-aem-package.js"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "axios": "^1.7.9",
    "fs-extra": "^11.2.0",
    "glob": "^10.5.0",
    "mammoth": "^1.12.0",
    "node-html-parser": "^7.1.0",
    "pdfjs-dist": "^4.8.69"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "docx": "^9.6.1",
    "pdf-lib": "^1.17.1"
  }
}
